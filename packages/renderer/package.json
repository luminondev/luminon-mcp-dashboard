{
  "name": "@mcp-dashboard/renderer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build -w @mcp-dashboard/shared && node ./scripts/clean-dist.mjs && node ./scripts/generate-static-demo.mjs && tsc -p tsconfig.server.json && vite build --config vite.config.ts",
    "dev": "concurrently \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "tsx src/api-server.ts",
    "dev:web": "vite --config vite.config.ts"
  },
  "dependencies": {
    "@mcp-dashboard/shared": "0.1.0",
    "@nivo/bar": "^0.88.0",
    "@nivo/line": "^0.88.0",
    "@nivo/pie": "^0.88.0",
    "@nivo/radar": "^0.88.0",
    "@nivo/scatterplot": "^0.88.0",
    "cors": "^2.8.5",
    "express": "^4.21.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-grid-layout": "^1.5.0",
    "react-resizable": "^3.0.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/react-grid-layout": "^1.3.5",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
